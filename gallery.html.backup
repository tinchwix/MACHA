                <div class="card gallery-item" data-category="sports"
                    style="padding: 0; overflow: hidden; cursor: pointer;">
                    <img src="assets/images/sports_basketball_01.jpg" alt="Volleyball Session"
                        style="width: 100%; height: 250px; object-fit: cover;">
                    <div style="padding: 1rem; text-align: center;">
                        <h5 style="margin: 0;">Volleyball Session</h5>
                    </div>
                </div>

                <div class="card gallery-item" data-category="sports"
                    style="padding: 0; overflow: hidden; cursor: pointer;">
                    <img src="assets/images/students_playing.jpg" alt="Recreational Sports"
