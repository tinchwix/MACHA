    <!-- Video Section -->
    <section class="section" style="background: var(--white);">
        <div class="container">
            <div class="text-center mb-xl">
                <h2>Campus Videos</h2>
                <p style="font-size: 1.125rem; color: var(--gray-600);">
                    Experience MACHA in motion
                </p>
            </div>

            <div class="grid grid-2">
                <div class="card" style="padding: 0; overflow: hidden;">
                    <div style="position: relative; padding-bottom: 56.25%;">
                        <img src="assets/images/campus_exterior_aerial.png" alt="Campus Tour"
                            style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;">
                        <div
                            style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5);">
                        </div>
                        <div
                            style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; color: white;">
                            <div style="font-size: 4rem; margin-bottom: 1rem;"><i class="fas fa-play"></i></div>
                            <h4 style="color: white;">Campus Tour 2026</h4>
                        </div>
                    </div>
                </div>

                <div class="card" style="padding: 0; overflow: hidden;">
                    <div style="position: relative; padding-bottom: 56.25%;">
                        <img src="assets/images/students_playing.jpg" alt="Student Life"
                            style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;">
                        <div
                            style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5);">
                        </div>
                        <div
                            style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; color: white;">
                            <div style="font-size: 4rem; margin-bottom: 1rem;"><i class="fas fa-play"></i></div>
                            <h4 style="color: white;">Student Life Highlights</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="section" style="background: var(--dark-gradient); color: white;">
        <div class="container text-center">
            <h2 style="color: white; margin-bottom: 1rem;">See It For Yourself</h2>
            <p style="font-size: 1.25rem; color: rgba(255,255,255,0.9); max-width: 700px; margin: 0 auto 2rem;">
                Schedule a campus visit to experience our vibrant community firsthand.
            </p>
            <div class="flex-center" style="gap: 1rem; flex-wrap: wrap;">
                <a href="contact.html" class="btn btn-primary btn-lg">Schedule a Visit</a>
                <a href="admissions.html" class="btn btn-outline btn-lg"
                    style="border-color: white; color: white;">Apply Now</a>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer-grid">
                <div class="footer-section">
                    <h4>MACHA</h4>
                    <p style="color: rgba(255,255,255,0.8); line-height: 1.6;">
                        Maasai Community Hope Academy - Transforming lives through Christ-centered education since 2009.
                        Serving the Maasai community with hope and excellence.
                    </p>
                </div>
                <div class="footer-section">
                    <h4>Quick Links</h4>
                    <ul class="footer-links">
                        <li><a href="about.html">About Us</a></li>
                        <li><a href="admissions.html">Admissions</a></li>
                        <li><a href="academics.html">Academics</a></li>
                        <li><a href="student-life.html">Student Life</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h4>Stay Updated</h4>
                    <p style="font-size: 0.875rem; color: rgba(255,255,255,0.7); margin-bottom: 1rem;">
                        Join our newsletter to receive the latest news and updates from MACHA.
                    </p>
                    <form id="newsletter-form" class="mt-sm">
                        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                            <input type="email" placeholder="Your Email" required
                                style="padding: 0.75rem 1rem; border-radius: var(--radius-md); border: none; flex: 1; min-width: 200px;">
                            <button type="submit" class="btn btn-primary btn-sm">Subscribe</button>
                        </div>
                    </form>
                </div>
                <div class="footer-section">
                    <h4>Contact Us</h4>
                    <ul class="footer-links">
                        <li><i class="fas fa-location-dot" style="margin-right: 10px;"></i> MAASAI COMMUNITY HOPE
                            ACADEMY - ENDOINYO ONKOPIT</li>
                        <li><i class="fas fa-box" style="margin-right: 10px;"></i> BOX 430 – 40700, KILGORIS</li>
                        <li><i class="fas fa-phone" style="margin-right: 10px;"></i> TEL: 0712598134 / 0724231396 /
                            0724762819</li>
                        <li><i class="fas fa-envelope" style="margin-right: 10px;"></i> macha.schools@gmail.com</li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2026 MACHA - Maasai Community Hope Academy. All rights reserved. | <a href="#"
                        style="color: rgba(255,255,255,0.8);">Privacy Policy</a> | <a href="#"
                        style="color: rgba(255,255,255,0.8);">Terms of Service</a></p>
            </div>
        </div>
    </footer>

    <script src="js/main.js"></script>
    <script>
        function filterGallery(category) {
            const items = document.querySelectorAll('.gallery-item');
            const buttons = document.querySelectorAll('.flex-center button');

            // Update button styles
            buttons.forEach(btn => {
                btn.className = 'btn btn-ghost';
            });
            event.target.className = 'btn btn-primary';

            // Filter items
            items.forEach(item => {
                if (category === 'all' || item.dataset.category === category) {
                    item.style.display = 'block';
                    item.style.animation = 'fadeIn 0.5s ease-out';
                } else {
                    item.style.display = 'none';
                }
            });
        }
    </script>
</body>

</html>