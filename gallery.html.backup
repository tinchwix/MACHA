                    <img src="assets/images/campus_grounds_02.jpg" alt="Main Campus Exterior"
                        style="width: 100%; height: 250px; object-fit: cover;">
                    <div style="padding: 1rem; text-align: center;">
                        <h5 style="margin: 0;">Main Campus Exterior</h5>
                    </div>
                </div>

                <div class="card gallery-item" data-category="campus"
                    style="padding: 0; overflow: hidden; cursor: pointer;">
                    <img src="assets/images/campus_grounds_01.jpg" alt="School Gate"
                        style="width: 100%; height: 250px; object-fit: cover;">
                    <div style="padding: 1rem; text-align: center;">
                        <h5 style="margin: 0;">School Gate</h5>
                    </div>
                </div>

                <div class="card gallery-item" data-category="campus"
                    style="padding: 0; overflow: hidden; cursor: pointer;">
                    <img src="assets/images/campus_exterior_aerial.png" alt="Campus Grounds"
                        style="width: 100%; height: 250px; object-fit: cover;">
                    <div style="padding: 1rem; text-align: center;">
                        <h5 style="margin: 0;">Campus Grounds</h5>
                    </div>
