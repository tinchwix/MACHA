    <!-- Hero -->
    <section class="hero hero-default animate" style="min-height: 60vh;">
        <div class="hero-content">
            <h1 class="hero-title">Gallery</h1>
            <p class="hero-subtitle">
                Capturing moments of excellence, growth, and community
            </p>
        </div>
    </section>

    <!-- Filter Buttons -->
    <section class="section-sm" style="background: var(--white);">
        <div class="container">
            <div class="flex-center" style="gap: 1rem; flex-wrap: wrap;">
                <button class="btn btn-primary" onclick="filterGallery('all')">All</button>
                <button class="btn btn-ghost" onclick="filterGallery('campus')">Campus</button>
                <button class="btn btn-ghost" onclick="filterGallery('events')">Events</button>
                <button class="btn btn-ghost" onclick="filterGallery('sports')">Sports</button>
                <button class="btn btn-ghost" onclick="filterGallery('arts')">Arts</button>
                <button class="btn btn-ghost" onclick="filterGallery('academics')">Academics</button>
            </div>
        </div>
    </section>

    <!-- Gallery Grid -->
    <section class="section" style="background: var(--gray-50);">
        <div class="container">
            <div class="grid grid-3">
